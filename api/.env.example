DATABASE_URL=postgresql+psycopg://postgres@localhost:5432/velib_wizard
CRON_SECRET=change-me-to-a-long-random-string
GBFS_BASE=https://velib-metropole-opendata.smovengo.cloud/opendata/Velib_Metropole
ALLOWED_ORIGINS=http://localhost:3000

# --- Render / production ---
# In Render dashboard set the following as service secrets:
#   DATABASE_URL          Supabase pooled URL (transaction mode, port 6543), prefix
#                         scheme as `postgresql+psycopg://...?sslmode=require`
#   CRON_SECRET           long random string; the same value goes into the
#                         cron-job.org job's X-Cron-Secret header
# And as regular env vars:
#   VELIB_RUN_SCHEDULER=0    keep the in-process APScheduler off in prod —
#                            cron-job.org drives the schedule instead
#   ALLOWED_ORIGINS          comma-separated allowed CORS origins for the
#                            dashboard (http://localhost:3000 for now)
